<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Allow the app to make outgoing network connections (API calls, OAuth) -->
  <key>com.apple.security.network.client</key>
  <true/>

  <!-- Allow spawning child processes (Python backend, Next.js) -->
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>

  <!-- Needed for JIT compilation in V8 (Electron renderer) -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>

  <!-- Disable library validation to allow loading unsigned dylibs -->
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>

  <!-- File system access for SQLite database in user data directory -->
  <key>com.apple.security.files.user-selected.read-write</key>
  <true/>

  <!-- Required for Apple Silicon Rosetta translation layer -->
  <key>com.apple.security.cs.allow-dyld-environment-variables</key>
  <true/>
</dict>
</plist>
