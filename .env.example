# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=presenton_dev
PRESENTON_DATABASE_URL=postgresql+asyncpg://presenton:presenton_dev@postgres:5432/presenton

# ── Redis ──────────────────────────────────────────────────────────────────────
PRESENTON_REDIS_URL=redis://redis:6379

# ── Security ───────────────────────────────────────────────────────────────────
# Symmetric key used by the auth domain for encrypting OAuth tokens (must be 32 bytes)
PRESENTON_ENCRYPTION_KEY=change-this-to-a-32-byte-secret!

# RSA private key PEM used by the identity domain for signing JWTs.
# Set PRESENTON_JWT_PUBLIC_KEY to the matching public key for the gateway.
PRESENTON_JWT_SECRET=change-this-jwt-secret
# PRESENTON_JWT_PRIVATE_KEY=
# PRESENTON_JWT_PUBLIC_KEY=

# ── CORS ───────────────────────────────────────────────────────────────────────
PRESENTON_ALLOWED_ORIGINS=http://localhost:5000,http://localhost:3000

# ── Runtime ────────────────────────────────────────────────────────────────────
PRESENTON_ENV=production
PRESENTON_LOG_JSON=true

# ── Frontend ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:5000

# ── AI Providers (configure at least one) ─────────────────────────────────────
# LLM=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=AIza...
